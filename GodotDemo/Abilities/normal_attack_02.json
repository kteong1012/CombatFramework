{
    "Name": "normal_attack_02",

    "Transforms": [
        {
            "To": "normal_attack_03",
            "Condition": {
                "$type": "HasModifier",
                "ModifierName": "combo3_window",
                "On": "Caster"
            }
        },
        {
            "To": "normal_attack_02_ex",
            "Condition": {
                "$type": "HasModifier",
                "ModifierName": "ex_point_buff",
                "On": "Caster"
            }
        }
    ],

    "AbilityModifiers": {
        "combo3_window": {
            "Name": "combo3_window",
            "DurationGetter": { "$type": "const", "Value": 0.8 },
            "IsHidden": true,
            "IsPurgable": false
        }
    },

    "AbilityEvents": {
        "OnSpellStart": [
            {
                "$type": "RemoveModifierActionData",
                "Target": { "$type": "SingleTargetSelector", "Type": "Caster" },
                "ModifierName": "combo2_window"
            },
            {
                "$type": "ForEachHitActionData",
                "Target": {
                    "$type": "BoxTargetSelector",
                    "Center": "Caster",
                    "Offset":        { "X": 120.0, "Y": 0.0, "Z": 0.0 },
                    "EulerRotation": { "X": 0.0, "Y": 0.0, "Z": 0.0 },
                    "Size":          { "X": 280.0, "Y": 160.0, "Z": 1.0 },
                    "Teams": "All"
                }
            },
            {
                "$type": "ApplyModifierActionData",
                "Target": { "$type": "SingleTargetSelector", "Type": "Caster" },
                "ModifierName": "combo3_window"
            }
        ],
        "OnHitTarget": [
            {
                "$type": "DamageActionData",
                "Target": { "$type": "SingleTargetSelector", "Type": "Target" },
                "Element": "FIRE",
                "Damage": {
                    "$type": "kxb",
                    "BaseStat": "Atk",
                    "K": { "$type": "const", "Value": 0.7 },
                    "B": { "$type": "const", "Value": 0.0 }
                },
                "Teams": "Enemy"
            }
        ]
    }
}
