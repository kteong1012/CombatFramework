{
    "Name": "radiance_aura",

    "AbilitySpecialFields": {
        "damage" : [
            1,
            2,
            3,
            4
        ],
        "radius": [
            200,
            300,
            400,
            500
        ],
        "effect_scale": [
            1,
            1.5,
            2,
            2.5
        ]
    },

    "AbilityEvents": {
        "OnEquipped": [
            {
                "$type": "ApplyModifierActionData",
                "Target": { "$type": "SingleTargetSelector", "Type": "Owner" },
                "ModifierName": "radiance_aura"
            }
        ],
        "OnUnequipped": [
            {
                "$type": "RemoveModifierActionData",
                "Target": { "$type": "SingleTargetSelector", "Type": "Owner" },
                "ModifierName": "radiance_aura"
            }
        ]
    },

    "AbilityModifiers": {
        "radiance_aura": {
            "Name": "radiance_aura",
            "StackMode": "Permanent",
            "IsHidden": true,
            "EffectName": "aura_range",
            "EffectScale": { "$type": "special", "Name": "effect_scale" },
            "ThinkInterval": 0.1,
            "Events": {
                "OnIntervalThink": [
                    {
                        "$type": "ApplyModifierActionData",
                        "Target": {
                            "$type": "AreaTargetSelector",
                            "Center": "Caster",
                            "Radius": { "$type": "special", "Name": "radius" },
                            "Teams": "Enemy"
                        },
                        "ModifierName": "radiance_burn"
                    }
                ]
            }
        },
        "radiance_burn": {
            "Name": "radiance_burn",
            "DurationGetter": { "$type": "const", "Value": 0.2 },
            "IsDebuff": true,
            "IsHidden": true,
            "ThinkInterval": 0.1,
            "Events": {
                "OnIntervalThink": [
                    {
                        "$type": "DamageActionData",
                        "Target": { "$type": "SingleTargetSelector", "Type": "Target" },
                        "Element": "FIRE",
                        "Damage": { "$type": "special", "Name": "damage" },
                        "Teams": "All"
                    }
                ]
            }
        }
    }
}
