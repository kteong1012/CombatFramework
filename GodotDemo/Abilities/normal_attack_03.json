{
    "Name": "normal_attack_03",
    "Tags": ["skill_type_normal_atk"],

    "Transforms": [
        {
            "To": "normal_attack_03_ex",
            "Condition": {
                "$type": "HasModifier",
                "ModifierName": "ex_point_buff",
                "On": "Caster"
            }
        }
    ],

    "AbilityEvents": {
        "OnSpellStart": [
            {
                "$type": "RemoveModifierActionData",
                "Target": { "$type": "SingleTargetSelector", "Type": "Caster" },
                "ModifierName": "combo3_window"
            },
            {
                "$type": "ForEachHitActionData",
                "Target": {
                    "$type": "BoxTargetSelector",
                    "Center": "Caster",
                    "Offset":        { "X": 140.0, "Y": 0.0, "Z": 0.0 },
                    "EulerRotation": { "X": 0.0, "Y": 0.0, "Z": 0.0 },
                    "Size":          { "X": 360.0, "Y": 200.0, "Z": 1.0 },
                    "Teams": "All"
                }
            }
        ],
        "OnHitTarget": [
            {
                "$type": "DamageActionData",
                "Target": { "$type": "SingleTargetSelector", "Type": "Target" },
                "Element": "FIRE",
                "Damage": {
                    "$type": "kxb",
                    "BaseStat": "Atk",
                    "K": { "$type": "const", "Value": 1.0 },
                    "B": { "$type": "const", "Value": 0.0 }
                },
                "Teams": "Enemy"
            }
        ]
    }
}
